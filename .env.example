OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=openai/gpt-oss-120b:free

FIREBASE_SERVICE_ACCOUNT_BASE64=base64_encoded_service_account_json
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STATE_COLLECTION=appState
FIREBASE_STATE_DOC=taitalk

LINE_CHANNEL_ID=your_line_login_channel_id
LINE_CHANNEL_SECRET=your_line_login_channel_secret
LINE_CALLBACK_URL=https://your-railway-domain.up.railway.app/api/auth/line/callback

# Frontend LIFF ID is not secret. V.b1 defaults to 2008685502-SecJ7r28.
# You can still override it with ?liffId=... or window.TAITALK_LIFF_ID.
